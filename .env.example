# Copy this file to .env and replace placeholders before online play.
# GENERALS_USER_ID is a private bot.generals.io bot id, not the display name.

GENERALS_AGENT=checkpoint:checkpoints/step1_step2_step3/model.pt
GENERALS_USER_ID=YOUR_PRIVATE_USER_ID
GENERALS_USERNAME="[Bot] your_bot_name"
GENERALS_ROOM_ID=your_private_room
GENERALS_MODE=private
GENERALS_DEVICE=cpu
GENERALS_LOG_DIR=artifacts/remote_matches/demo
GENERALS_FORCE_START=true
